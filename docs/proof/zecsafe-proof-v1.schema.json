{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zecsafe.local/schemas/zecsafe-proof-v1.schema.json",
  "title": "zecsafe-proof-v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project",
    "network",
    "run_id",
    "recorded_at",
    "zecsafe_commit",
    "vault",
    "availability",
    "intent",
    "pczt",
    "frost",
    "transaction",
    "toolchain",
    "evidence",
    "limitations",
    "bundle_hash"
  ],
  "properties": {
    "schema_version": { "const": "zecsafe-proof-v1" },
    "project": { "const": "ZecSafe" },
    "network": { "enum": ["main", "test"] },
    "run_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$" },
    "recorded_at": { "type": "string", "format": "date-time" },
    "zecsafe_commit": { "type": "string", "pattern": "^(unknown|[0-9a-f]{7,64})$" },
    "bundle_hash": { "$ref": "#/$defs/sha256" },
    "vault": {
      "type": "object",
      "additionalProperties": false,
      "required": ["group_fingerprint", "ciphersuite", "threshold", "participants_total"],
      "properties": {
        "group_fingerprint": { "$ref": "#/$defs/sha256" },
        "ciphersuite": { "type": "string", "minLength": 1 },
        "threshold": { "type": "integer", "minimum": 1 },
        "participants_total": { "type": "integer", "minimum": 1 }
      }
    },
    "availability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available", "unavailable"],
      "properties": {
        "available": { "type": "integer", "minimum": 0 },
        "unavailable": { "type": "integer", "minimum": 0 }
      }
    },
    "intent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commitment"],
      "properties": {
        "commitment": { "$ref": "#/$defs/sha256" }
      }
    },
    "pczt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_fingerprint",
        "signed_fingerprint",
        "proven_fingerprint",
        "final_fingerprint",
        "source_binding_report_ref",
        "final_binding_report_ref",
        "binding_status",
        "signed_pczt_status",
        "proven_pczt_status",
        "combine_status",
        "checks"
      ],
      "properties": {
        "source_fingerprint": { "$ref": "#/$defs/sha256" },
        "signed_fingerprint": { "$ref": "#/$defs/sha256" },
        "proven_fingerprint": { "$ref": "#/$defs/sha256" },
        "final_fingerprint": { "$ref": "#/$defs/sha256" },
        "source_binding_report_ref": { "$ref": "#/$defs/sha256" },
        "final_binding_report_ref": { "$ref": "#/$defs/sha256" },
        "binding_status": { "enum": ["PASS", "FAIL", "BLOCKED"] },
        "signed_pczt_status": { "enum": ["PASS", "FAIL", "BLOCKED"] },
        "proven_pczt_status": { "enum": ["PASS", "FAIL", "BLOCKED"] },
        "combine_status": { "enum": ["PASS", "FAIL", "BLOCKED"] },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["field", "status"],
            "properties": {
              "field": { "type": "string", "minLength": 1 },
              "status": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "frost": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "group_fingerprint",
        "pczt_fingerprint",
        "binding_report_ref",
        "session_fingerprint",
        "selected_signers",
        "unavailable_participants",
        "threshold_status",
        "aggregate_signature_status",
        "aggregate_signature_fingerprint",
        "signature_byte_length",
        "sighash_fingerprint"
      ],
      "properties": {
        "group_fingerprint": { "$ref": "#/$defs/sha256" },
        "pczt_fingerprint": { "$ref": "#/$defs/sha256" },
        "binding_report_ref": { "$ref": "#/$defs/sha256" },
        "session_fingerprint": { "$ref": "#/$defs/sha256" },
        "selected_signers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/sha256" }
        },
        "unavailable_participants": { "type": "integer", "minimum": 0 },
        "threshold_status": { "type": "string", "minLength": 1 },
        "aggregate_signature_status": { "type": "string", "minLength": 1 },
        "aggregate_signature_fingerprint": { "$ref": "#/$defs/sha256" },
        "signature_byte_length": { "type": "integer", "minimum": 1 },
        "sighash_fingerprint": { "$ref": "#/$defs/sha256" }
      }
    },
    "transaction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["txid", "chain_status", "broadcast_status", "observed_block_height", "confirmations_at_recording"],
      "properties": {
        "txid": {
          "anyOf": [
            { "type": "null" },
            { "type": "string", "pattern": "^[0-9a-f]{64}$" }
          ]
        },
        "chain_status": { "enum": ["NOT_BROADCAST", "SUBMITTED", "OBSERVED", "MINED", "CONFIRMED", "REJECTED", "UNKNOWN"] },
        "broadcast_status": { "enum": ["NOT_BROADCAST", "SUBMITTED", "OBSERVED", "MINED", "CONFIRMED", "REJECTED", "UNKNOWN"] },
        "observed_block_height": {
          "anyOf": [
            { "type": "null" },
            { "type": "integer", "minimum": 0 }
          ]
        },
        "confirmations_at_recording": { "type": "integer", "minimum": 0 }
      }
    },
    "toolchain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["frost_tools_commit", "zcash_devtool_commit", "pczt_signer_library_commit"],
      "properties": {
        "frost_tools_commit": { "type": "string", "pattern": "^(unknown|[0-9a-f]{7,64})$" },
        "zcash_devtool_commit": { "type": "string", "pattern": "^(unknown|[0-9a-f]{7,64})$" },
        "pczt_signer_library_commit": { "type": "string", "pattern": "^(unknown|[0-9a-f]{7,64})$" }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_binding_report_ref", "final_binding_report_ref", "completion_report_ref", "proof_event_ref"],
      "properties": {
        "source_binding_report_ref": { "$ref": "#/$defs/sha256" },
        "final_binding_report_ref": { "$ref": "#/$defs/sha256" },
        "completion_report_ref": { "$ref": "#/$defs/sha256" },
        "proof_event_ref": { "$ref": "#/$defs/sha256" }
      }
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
