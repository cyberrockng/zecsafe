+fn is_pre_ironwood_server(status: &tonic::Status) -> bool {
+    status.code() == tonic::Code::Unknown
+        && status
+            .message()
+            .eq_ignore_ascii_case("unrecognized shielded protocol")
+}
+
+#[cfg(test)]
+mod tests {
+    use super::is_pre_ironwood_server;
+
+    #[test]
+    fn identifies_only_the_known_pre_ironwood_response() {
+        assert!(is_pre_ironwood_server(&tonic::Status::unknown(
+            "unrecognized shielded protocol"
+        )));
+        assert!(!is_pre_ironwood_server(&tonic::Status::invalid_argument(
+            "unrecognized shielded protocol"
+        )));
+        assert!(!is_pre_ironwood_server(&tonic::Status::unknown(
+            "another server error"
+        )));
+    }
+}
